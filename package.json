    "date-fns": "^3.6.0",
    "echarts": "^6.1.0",
    "lodash": "^4.18.1",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.2",
    "react-helmet": "^6.1.0",
