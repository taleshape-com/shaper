{
  "name": "shaper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite ui",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build",
    "build": "npm run build:main && npm run build:embed",
    "build:main": "vite build ui",
    "build:embed": "vite build -c ui/vite.embed.ts",
    "typecheck": "tsc -b ui",
    "test": "vitest run",
    "lint": "eslint -c ui/eslint.config.js",
    "format": "eslint -c ui/eslint.config.js --fix"
  },
  "dependencies": {
