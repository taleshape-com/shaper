    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-helmet": "^6.1.11",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
